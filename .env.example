# ── Database (Supabase) ────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_ID.supabase.co:5432/postgres

# ── Flask ──────────────────────────────────────
SECRET_KEY=change-me-in-production
DEBUG=False

# ── Scanner ────────────────────────────────────
SCAN_INTERVAL_MINUTES=5
STRONG_SIGNAL_THRESHOLD=7

# ── Phase 3: Telegram ──────────────────────────
# 1. Message @BotFather on Telegram -> /newbot
# 2. Add bot to your group/channel
# 3. Get chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Phase 3: Claude AI explanations ───────────
# Get from: console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=

# ── Optional: Binance / CoinGecko ─────────────
COINGECKO_API_KEY=
BINANCE_API_KEY=
BINANCE_SECRET=
